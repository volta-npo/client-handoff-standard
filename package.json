{
  "name": "@volta-oss/client-handoff-standard",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "A polished handoff ritual so owners can actually maintain what students build.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/client-handoff-standard:local .",
    "docker:run": "docker compose up --build"
  },
  "keywords": [
    "digital-equity",
    "local-first",
    "oss",
    "student agency operations",
    "release",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/client-handoff-standard.git"
  },
  "homepage": "https://volta-npo.github.io/client-handoff-standard/",
  "bugs": {
    "url": "https://github.com/volta-npo/client-handoff-standard/issues"
  },
  "author": "Volta Open Source <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
